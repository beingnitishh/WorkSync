model Employee {
  id                      String   @id @default(cuid())
  name                    String
  startDate               String
  monthlySalary           Float
  firstSundayPattern      String   @default("HALF_DAY")
  salaryCalculationMethod String   @default("FIXED_30_DAYS")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  attendance              Attendance[]
}

model Attendance {
  id               String   @id @default(cuid())
  date             String
  status           String   @default("FULL_DAY")
  payableValue     Float    @default(1.0)
  note             String?
  isAutoGenerated  Boolean  @default(false)
  isManualOverride Boolean  @default(false)
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([date, employeeId])
}

model Holiday {
  id        String   @id @default(cuid())
  date      String   @unique  // YYYY-MM-DD format
  name      String
  recurring Boolean  @default(false)  // If true, repeats every year
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
